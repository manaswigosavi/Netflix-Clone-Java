<!DOCTYPE html>
<html>
<head>
    <title>Netflix Clone</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header class="navbar">
        <h1 class="logo">NETFLIX</h1>
        <nav>
            <a href="home.jsp">Home</a>
            <a href="login.jsp">Login</a>
            <a href="signup.jsp">Sign Up</a>
            <a href="logout">Logout</a>
        </nav>
    </header>

    <section class="banner">
        <h2>Welcome to Netflix</h2>
        <p>Watch your favorite movies anytime!</p>
    </section>

    <section class="movies">
        <h2>Popular Movies</h2>
        <div class="movie-row">
            <img src="posters/chhava.jpg" alt="Chhava">
            <img src="posters/darkknight.jpg" alt="Dark Knight">
            <img src="posters/demonslayer.jpg" alt="Demon Slayer">
            <img src="posters/inception.jpg" alt="Inception">
            <img src="posters/interstellar.jpg" alt="Interstellar">
            <img src="posters/jabwemet.jpg" alt="Jab We Met">
            <img src="posters/yjhd.jpg" alt="YJHD">
        </div>
    </section>
</body>
</html>